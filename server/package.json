  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.5.13",
    "@vitest/coverage-v8": "^3.2.6",
