<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>BeeUrEi</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<key>NSCameraUsageDescription</key>
	<string>用于通过摄像头实时识别前方障碍并向你语音提示，以及在你呼叫志愿者时传输画面。</string>
	<key>NSHumanReadableCopyright</key>
	<string>© 2026 Hiko Sphere 彦穹科技 · 软件制作人 Li Yanpei Hiko</string>
	<key>NSLocalNetworkUsageDescription</key>
	<string>用于连接你自托管的 BeeUrEi 后端（局域网内）。</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>用于规划步行路线并播报你途经的路口与地标。</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>用于与远程志愿者实时语音交流、发送语音消息和语音指令。</string>
	<key>NSMotionUsageDescription</key>
	<string>用于 AirPods 头部追踪提升空间音方向准确度，以及检测疑似摔倒以便通知亲友。</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>用于语音指令：说出'我在哪''带我去某地'等即可直达对应功能（优先在设备端识别）。</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
		<string>voip</string>
	</array>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
		<string>arkit</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
</dict>
</plist>
