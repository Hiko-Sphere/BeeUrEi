# 复制为 .env 并填入真实值（.env 不会被提交）。
# 高德开放平台 Key（lbs.amap.com → 应用管理 → 我的应用 → 创建 Key）。
# ⚠️ 平台必须选「Web服务」。iOS/Android/JS-API 类型的 Key 调 restapi.amap.com 会返回
#   {"status":"0","infocode":"10009","info":"USERKEY_PLAT_NOMATCH"}，导航将失败（后端日志会打印此 infocode）。
AMAP_API_KEY=your_amap_web_service_key_here

# 管理员引导（可选）：启动时若不存在则创建该管理员
ADMIN_USERNAME=root
ADMIN_PASSWORD=change_me_strong

# JWT 签名密钥（生产务必改成强随机值）
JWT_SECRET=change_me_in_production

# WebRTC ICE 服务器。STUN 可用公共；TURN 为自托管 coturn（见 server/coturn/）。
# 设 TURN_SECRET（与 coturn static-auth-secret 一致）+ TURN_URLS 后，/api/assist/turn 才下发 TURN 凭据。
STUN_URLS=stun:stun.l.google.com:19302
TURN_URLS=turn:YOUR_PUBLIC_IP:3478
TURN_SECRET=change_me_same_as_coturn

# 邮件（D1 邮箱验证 / 找回密码）。不配 SMTP_HOST 时验证码打印到服务器日志（自托管可用）。
# 配置后需安装依赖：cd server && npm i nodemailer
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=your_smtp_password
SMTP_FROM=BeeUrEi <no-reply@yourdomain.com>

# 监控（D3/F2）。Prometheus 抓取 /metrics；设了 METRICS_TOKEN 则需 Authorization: Bearer <token>。
METRICS_TOKEN=change_me_scrape_token
# 崩溃/错误上报（可选，需 npm i @sentry/node）：
SENTRY_DSN=https://xxxx@oXXXX.ingest.sentry.io/XXXX
SENTRY_TRACES_SAMPLE_RATE=0.1

# 后台来电 VoIP 推送（A1）。四项齐全才启用，否则仅前台轮询会合（无后台/锁屏响铃）。
# .p8 来自 Apple 开发者后台 → Keys → 新建 APNs Auth Key；TOPIC 为 BundleID + .voip。
APNS_KEY_PATH=/path/to/AuthKey_XXXXXX.p8
APNS_KEY_ID=XXXXXXXXXX
APNS_TEAM_ID=YYYYYYYYYY
APNS_TOPIC=com.beeurei.BeeUrEi.voip
# 开发(Xcode 真机调试)用 sandbox；TestFlight/App Store 用 api.push.apple.com。
# 注意：不要写行内注释（Node 末行解析可能不剥离 # 后内容，污染 host 值）。
APNS_HOST=api.sandbox.push.apple.com

# ── AI 场景描述 / 图像问答（视觉大模型，见 vision/visionClient.ts）──
# provider 无关：任何 OpenAI 兼容的 /chat/completions 视觉端点均可（智谱 GLM-4V、通义 Qwen-VL、
# OpenAI 等）。三项齐全才启用，否则 /api/vision/describe 返回 503 ai_not_configured（fail-closed）。
# VISION_API_BASE 填到 /v1（代码会自动拼 /chat/completions）。示例（智谱）：
#   VISION_API_BASE=https://open.bigmodel.cn/api/paas/v4
#   VISION_MODEL=glm-4v-flash
# 示例（通义）： VISION_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1  VISION_MODEL=qwen-vl-plus
VISION_API_KEY=your_vision_provider_api_key
VISION_API_BASE=https://open.bigmodel.cn/api/paas/v4
VISION_MODEL=glm-4v-flash
# 可选：回复最大 token 数（默认 500）与上游超时毫秒（默认 30000，视觉推理慢但绝不无限挂起）。
# VISION_MAX_TOKENS=500
# VISION_TIMEOUT_MS=30000

# ── 数据库 / 存储路径 ────────────────────────────────────────────
# 存储驱动：默认 SQLite（需 Node --experimental-sqlite）；设 DB_DRIVER=json 用 JSON 文件（自托管轻量，见 JsonFileStore）。
# DB_DRIVER=json
# 数据库路径：SQLite 默认 data/beeurei.db；JSON 驱动默认 data/db.json。生产经持久卷挂载。
DB_PATH=data/beeurei.db
# 媒体文件（视频消息等大文件）磁盘目录，默认 data/media。生产经持久卷挂载。
MEDIA_DIR=data/media

# ── KYC 实名认证加密（证件图片信封加密，见 kyc/crypto.ts）─────────
# 启用 KYC 时必填：主密钥，必须为 64 位十六进制（openssl rand -hex 32 生成 32 字节）。
# 未配置/格式错误 → 加解密证件时抛错（fail-closed，绝不明文落盘）。
# 必须不同于 JWT_SECRET——否则令牌密钥一旦泄露即可解密全部证件（代码会拒绝相同值）。
KYC_ENC_KEY=change_me_openssl_rand_hex_32
# 证件密文隔离目录，默认 data/kyc（权限 0700，仅服务进程可读写）。
KYC_DIR=data/kyc

# ── Passkey / WebAuthn（免密登录，见 routes/passkey.ts）───────────
# RP ID 必须等于服务对外域名（默认 beeurei-api.hikosphere.com）。换域名务必同步改这三项，否则 passkey 注册/校验全部失败。
PASSKEY_RP_ID=beeurei-api.hikosphere.com
PASSKEY_RP_NAME=BeeUrEi
# 允许发起 passkey 的前端源，默认 https://<PASSKEY_RP_ID>；多个用逗号分隔。
PASSKEY_RP_ORIGIN=https://beeurei-api.hikosphere.com

# ── Sign in with Apple（见 auth/apple.ts）─────────────────────────
# audience 必须是 App 的 Bundle ID；未配置则 Apple 登录端点返回 503（不假装成功）。
APPLE_BUNDLE_ID=com.beeurei.BeeUrEi
APPLE_TEAM_ID=7CDDP73WJS

# ── CORS（网页协助端跨源调用 API，见 app.ts）──────────────────────
# 允许的前端源，默认 https://beeurei.hikosphere.com；多个用逗号分隔。换网页域名务必改。
CORS_ORIGINS=https://beeurei.hikosphere.com

# ── 服务端口（可选，默认 8787）────────────────────────────────────
PORT=8787
